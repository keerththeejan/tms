Options -Indexes

# Ensure consistent UTF-8 rendering on cPanel (fixes Tamil/encoding)
AddDefaultCharset UTF-8
AddCharset UTF-8 .php .html .htm .css .js .json .xml .svg

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /TMS/

  # Send everything to public/index.php
  RewriteCond %{REQUEST_URI} !^/TMS/public/
  RewriteRule ^ public/ [L]
</IfModule>
